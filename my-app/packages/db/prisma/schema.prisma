generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id          Int           @id @default(autoincrement())
    email       String        @unique
    username    String        @unique
    password    String
    userId      String        @unique
    role        Role          @default(STUDENT)
    balance     Float         @default(0)
    createdAt   DateTime      @default(now())
    transaction Transaction[] @relation("StudentTransactions")

    @@index([username])
    @@index([role])
}

model Transaction {
    id          Int               @id @default(autoincrement())
    username    String
    amount      Float             @default(0)
    type        TransactionType
    description String
    status      TransactionStatus @default(PENDING)
    createdAt   DateTime          @default(now())
    studentId   Int
    student     User              @relation("StudentTransactions", fields: [studentId], references: [id])

    @@index([studentId])
    @@index([createdAt])
    @@index([status])
}

model Expense {
    id          Int      @id @default(autoincrement())
    amount      Float
    description String
    createdAt   DateTime @default(now())

    @@index([createdAt])
}

model benefice {
    id          Int      @id @default(autoincrement())
    amount      Float
    description String
    createdAt   DateTime @default(now())

    @@index([createdAt])
}

model Global {
    id    Int   @id
    total Float @default(0)
}

enum Role {
    STUDENT
    ADMIN
}

enum TransactionStatus {
    PENDING
    CONFIRMED
    REJECTED
}

enum TransactionType {
    DEPOSIT
    EXPENSE
}
